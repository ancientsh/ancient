{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:frontend": "bun --hot src/index.ts",
    "dev:anvil": "anvil",
    "deploy:contracts": "cd contracts && forge script script/Deploy.s.sol --rpc-url http://localhost:8545 --broadcast --chain-id 31337",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "fly:deploy": "bun run build && flyctl deploy --ha=false",
    "fly:logs": "flyctl logs",
    "fly:status": "flyctl status",
    "fly:ssh": "flyctl ssh console"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "liquidcn": "^0.1.0-alpha.15",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.3.1",
    "viem": "^2.44.4"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
